# Copy to .env and fill in the required values. Never commit .env.

# Database — required
DB_PASSWORD=changeme
DB_NAME=supfile_dev
DB_USER=supfile

# Auth — generate a strong random string for production (required)
# node -e "require('crypto').randomBytes(32).toString('hex').then?console.log:console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace-with-long-random-string
JWT_EXPIRES_IN=7d

# Origins
CLIENT_ORIGIN=http://localhost:4000
NEXT_PUBLIC_API_URL=http://localhost:3000

# OAuth2 — optional, leave empty to disable Google/GitHub login
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
OAUTH_CALLBACK_URL=http://localhost:3000/auth/oauth/google/callback
GITHUB_CALLBACK_URL=http://localhost:3000/auth/oauth/github/callback

# File encryption — optional, 64 hex chars (32 bytes). Leave empty to store unencrypted.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=
