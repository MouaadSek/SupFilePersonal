# Copy to .env and replace placeholders. Never commit .env or real secrets.

NODE_ENV=development

# API
PORT=3000

# Database (example — adjust to your stack)
DATABASE_URL=postgresql://supfile:changeme@localhost:5432/supfile_dev
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=supfile_dev
# DB_USER=supfile
# DB_PASSWORD=changeme

# Auth — generate a strong random value for production
JWT_SECRET=replace-with-long-random-string
JWT_EXPIRES_IN=7d

# OAuth / third-party (example)
# OAUTH_CLIENT_ID=your-client-id
# OAUTH_CLIENT_SECRET=your-client-secret
