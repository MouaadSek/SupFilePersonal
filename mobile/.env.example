# SUPFile API (Expo reads EXPO_PUBLIC_* at bundle time — restart with -c after changes)
EXPO_PUBLIC_API_URL=http://localhost:3000

# Google Sign-In (OAuth 2.0 client IDs from Google Cloud Console)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your-ios-client-id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=your-android-client-id.apps.googleusercontent.com

# Android emulator → host machine:
# EXPO_PUBLIC_API_URL=http://10.0.2.2:3000

# Physical device → LAN IP of the PC running the API (port 3000):
# EXPO_PUBLIC_API_URL=http://192.168.1.42:3000

# Dev tunnel — use https (tunnel redirects HTTP → HTTPS)
# EXPO_PUBLIC_API_URL=https://YOUR-TUNNEL.uks1.devtunnels.ms

# Backend: ~/Downloads/supfileDev-mouaad/server — copy .env.example, set JWT_SECRET + DB_PASSWORD, npm run dev
